# ====================================================================
# weather_traffic — Environment Variables Example
# ====================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# --------------------------------------------------------------------

# ===== Anthropic API (for AI agent) =====
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ===== MET Norway (weather data) =====
# No API key required, but a descriptive User-Agent IS required.
# See: https://api.met.no/doc/TermsOfService
MET_USER_AGENT=weather_traffic/0.1 (https://github.com/Ravskiitis/weather_traffic)

# ===== Statens vegvesen — Datex II (traffic incidents) =====
# HTTP Basic Auth is required. Registration is free of charge.
# Register at: https://www.vegvesen.no/en/fag/technology/open-data/a-selection-of-open-data/what-is-datex/get-access/
# License: Norwegian Licence for Open Government Data (NLOD) / CC BY 4.0
# Attribution: "Statens vegvesen / NPRA" must appear in any UI displaying this data.
# Note: credentials are server-side only — never expose them to the browser.
VEGVESEN_USERNAME=
VEGVESEN_PASSWORD=

# ===== Statens vegvesen — Trafikkdata GraphQL =====
# Public, no key required.
# Reference only; no secret needed at this stage.

# ===== Backend =====
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/weather_traffic.db

# ===== Frontend =====
PUBLIC_BACKEND_URL=http://localhost:8000

# ===== Application settings =====
DATA_REGION=bergen
DEFAULT_LANGUAGE=en
LOG_LEVEL=info
