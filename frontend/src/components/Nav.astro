---
import LanguageToggle from '../islands/LanguageToggle';

interface Props {
  activeTab?: string;
}

const { activeTab = 'dashboard' } = Astro.props;
---

<nav class="sticky top-0 z-50 border-b border-brand-border bg-white">
  <div class="mx-auto flex h-14 max-w-7xl items-center gap-4 px-6">
    <!-- Logo -->
    <a
      href="/"
      class="flex shrink-0 select-none items-baseline font-bold text-lg leading-none"
    >
      <span class="text-brand-slate">weather</span>
      <span class="text-brand-orange">_</span>
      <span class="font-medium text-brand-mid">traffic</span>
    </a>

    <!-- Nav tabs -->
    <div class="ml-4 flex items-center gap-1">
      <a
        href="/"
        class={`inline-flex items-center rounded-md px-3 py-1.5 text-sm font-medium transition-colors ${activeTab === 'dashboard' ? 'bg-brand-light text-brand-slate' : 'text-brand-mid hover:bg-brand-light/50 hover:text-brand-slate'}`}
      >
        Dashboard
      </a>
    </div>

    <div class="flex-1" />

    <!-- Language toggle (React island) -->
    <LanguageToggle client:load />

    <!-- Notification bell -->
    <button
      aria-label="Notifications"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md text-brand-mid transition-colors hover:bg-brand-light hover:text-brand-slate"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" />
        <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
      </svg>
    </button>

    <!-- Avatar -->
    <button
      aria-label="User menu"
      class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-orange text-sm font-semibold text-white transition-colors hover:bg-brand-orange-dark"
    >
      F
    </button>
  </div>
</nav>
