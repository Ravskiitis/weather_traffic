---
interface Props {
  title?: string;
  lang?: 'en' | 'no';
}

const { title = 'Dashboard', lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bergen weather and traffic operations dashboard" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} — weather_traffic</title>
  </head>
  <body class="min-h-screen bg-brand-page font-sans text-brand-slate antialiased">
    <slot />
  </body>
</html>
