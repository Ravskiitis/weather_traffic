---
interface Props {
  title?: string;
  lang?: 'en' | 'no';
}

const { title = 'weather_traffic', lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bergen weather and traffic dashboard" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — weather_traffic</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 antialiased">
    <slot />
  </body>
</html>
