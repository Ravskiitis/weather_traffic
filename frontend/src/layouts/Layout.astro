---
interface Props {
  title?: string;
  lang?: 'en' | 'no';
}

const { title = 'Dashboard', lang = 'en' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bergen weather and traffic operations dashboard" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} — weather_traffic</title>
  </head>

  <style is:global>
    @media print {
      @page {
        size: A4 portrait;
        margin: 15mm 20mm;
      }

      /* Conceal everything; only the report card will be visible */
      body * {
        visibility: hidden;
      }
      #wt-report-card,
      #wt-report-card * {
        visibility: visible;
      }

      /* Anchor the card at the page origin so it starts at the top */
      #wt-report-card {
        position: absolute;
        inset: 0;
        border-left: none !important;   /* drop orange accent — looks odd in print */
        box-shadow: none !important;
        border-radius: 0 !important;
        overflow: visible !important;   /* allow content to paginate */
      }

      /* Force full sections visible regardless of the collapsed JS state */
      #wt-report-card .wt-full-sections {
        display: grid !important;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        padding-top: 1rem;
        border-top: 1px solid #e2e5eb;
      }
    }
  </style>
  <body class="min-h-screen bg-brand-page font-sans text-brand-slate antialiased">
    <slot />
  </body>
</html>
