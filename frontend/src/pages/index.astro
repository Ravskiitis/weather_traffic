---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard">
  <main class="flex min-h-screen flex-col items-center justify-center gap-4 p-8">
    <h1 class="text-2xl font-semibold text-gray-800">weather_traffic</h1>
    <p class="text-gray-500">Frontend skeleton ready — dashboard implementation pending.</p>
    <a
      href="http://localhost:8000/api/health"
      target="_blank"
      class="rounded-md bg-gray-100 px-4 py-2 text-sm font-mono text-gray-600 hover:bg-gray-200"
    >
      Check backend health →
    </a>
  </main>
</Layout>
